---
--- >>> P.parse pJsonPath "" "->1"
--- Right [JArrow {jOp = JIdx {jVal = "+1"}}]
---
--- >>> P.parse pJsonPath "" "->>text"
--- Right [J2Arrow {jOp = JKey {jVal = "text"}}]
---
--- >>> P.parse pJsonPath "" "->>1"
--- Right [J2Arrow {jOp = JIdx {jVal = "+1"}}]
---
--- >>> P.parse pJsonPath "" "->0,other"
--- Right [JArrow {jOp = JIdx {jVal = "+0"}}]
---
--- >>> P.parse pJsonPath "" "->0.desc"
--- Right [JArrow {jOp = JIdx {jVal = "+0"}}]
