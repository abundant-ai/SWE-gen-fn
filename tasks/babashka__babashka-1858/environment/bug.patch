           (with-out-str (apply main args))
-          (do (apply main args)
+          (do (run args)
               (binding [*out* *err*]
                 (println "ran" n "times"))))))
-    (let [{:keys [exit force-exit]} (apply main args)]
-      ;; only necessary for linux musl, but for compat, we do it everywhere:
-      (shutdown-agents)
-      (when (or (not (zero? exit))
-                force-exit)
-        (System/exit exit)))))
+    (let [exit-code (run args)]
+      (System/exit exit-code))))
 
