FROM ubuntu:24.04

# Base system packages (common to all languages)
RUN apt-get update && apt-get install -y \
    git \
    curl \
    ca-certificates \
    patch \
    build-essential \
    zlib1g-dev \
    libtinfo-dev \
    libgmp-dev \
    libffi-dev \
    libncurses-dev \
    wget \
    xz-utils \
    locales \
    && rm -rf /var/lib/apt/lists/*

# Set up locale for Haskell builds
RUN locale-gen en_US.UTF-8
ENV LANG=en_US.UTF-8 \
    LC_ALL=en_US.UTF-8

# Install GHCup and use it to install GHC 9.2.5 and Cabal
RUN curl --proto '=https' --tlsv1.2 -sSf https://get-ghcup.haskell.org | \
    BOOTSTRAP_HASKELL_NONINTERACTIVE=1 BOOTSTRAP_HASKELL_GHC_VERSION=9.2.5 BOOTSTRAP_HASKELL_INSTALL_NO_STACK=1 sh

ENV PATH="/root/.ghcup/bin:/root/.cabal/bin:${PATH}"

# Install happy (parser generator required by purescript)
RUN cabal update && cabal install happy-1.20.0

# Install Node.js (required for tests)
RUN curl -fsSL https://deb.nodesource.com/setup_16.x | bash - && \
    apt-get install -y nodejs && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Clone repo at HEAD commit (with fix applied)
RUN git clone https://github.com/purescript/purescript.git src && \
    cd src && \
    (git fetch --depth 1 origin 590c0c63a3fb6e06166911e4240869ed92ad82af || git fetch --depth 1 origin "+refs/pull/4523/head:refs/remotes/origin/pr/4523") && \
    git checkout --detach FETCH_HEAD && \
    git submodule update --init --recursive

WORKDIR /app/src

# Update cabal package list and install dependencies
# Use -j to parallelize builds
RUN cabal update && \
    cabal build -j4 --only-dependencies all

# If install/build steps touched tracked files, reset them so bug.patch applies cleanly,
RUN git reset --hard

# Apply bug.patch to revert to buggy state (BASE)
COPY bug.patch /tmp/bug.patch
RUN patch -p1 < /tmp/bug.patch && rm /tmp/bug.patch

# Rebuild after applying bug.patch (Haskell is compiled)
RUN cabal build -j4 all

RUN rm -rf /app/src/.git

WORKDIR /app/src
