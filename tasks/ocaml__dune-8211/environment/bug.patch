+                     let decode =
+                       Syntax.set Dune_lang.Pkg.syntax (Active version)
+                         Pkg.decode
+                     in
+                     String_with_vars.set_decoding_env env decode
+                   in
+                   (Dune_lang.Decoder.parse parser Univ_map.empty
+                      (List (Loc.none, sexp)))
+                     ~lock_dir:path name
+                 in
+                 (name, package))
+          >>| Package.Name.Map.of_list_exn
+        in
+        { packages; version; ocaml })
 end
 
