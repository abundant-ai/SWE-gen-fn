+      Install_action.Spec.collect [ root ] []
+      |> List.iter ~f:(fun src ->
+        let dst =
+          Path.append_local (Path.build dst) (Path.drop_prefix_exn src ~prefix:root)
+        in
+        let old_permissions =
+          match Path.Untracked.stat dst with
+          | Error _ -> None
+          | Ok s ->
+            Path.unlink dst;
+            Some s.st_perm
+        in
