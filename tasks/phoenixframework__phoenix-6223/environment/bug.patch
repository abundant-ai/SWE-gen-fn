-
-    def handle_info({:debug_channels, ref, reply_to}, state) do
-      send(
-        reply_to,
-        {:debug_channels, ref, [%{pid: state, status: :joined, topic: "room:lobby"}]}
-      )
-
-      {:noreply, state}
-    end
-  end
-
-  defmodule FakeChannel do
