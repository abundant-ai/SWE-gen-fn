+(defn repl-read [sci-ctx in-stream _request-prompt request-exit]
+  (if (nil? (r/peek-char in-stream))
+    request-exit
+    (let [v (parser/parse-next sci-ctx in-stream)]
+      (skip-if-eol in-stream)
+      (if (or (identical? :repl/quit v)
+            (identical? :repl/exit v))
+        request-exit
+        v))))
+
