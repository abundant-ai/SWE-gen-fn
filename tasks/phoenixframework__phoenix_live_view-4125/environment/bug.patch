-  defp store_component_call(component, attr_info, slot_info, line, %{caller: caller} = state) do
-    module = caller.module
-
-    if module && Module.open?(module) do
-      pruned_slots =
-        for {slot_name, slot_values} <- slot_info, into: %{} do
