       match
         Package_name.Map.of_list_map opam_packages_to_lock ~f:(fun opam_package ->
@@ -689,5 +670,5 @@ let solve_lock_dir
             , files ))
       |> Package_name.Map.of_list_exn
     in
-    { Solver_result.summary; lock_dir; files })
+    { Solver_result.lock_dir; files })
