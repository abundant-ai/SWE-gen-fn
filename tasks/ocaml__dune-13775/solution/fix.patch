+      | Blang.Const b when b <> identity -> None
+      | Blang.Const _ -> Some []
+      | b -> Some [ b ]))
+  |> Option.map ~f:(fun blangs ->
+    List.fold_left blangs ~init:[] ~f:(fun acc b ->
+      if List.exists acc ~f:(blang_equal b) then acc else b :: acc)
+    |> List.rev)
