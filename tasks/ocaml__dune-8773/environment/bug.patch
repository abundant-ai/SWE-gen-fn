-
-let%expect_test "two immediate and one transitive" =
-  test 0 2 0 1;
-  [%expect {| [Success]  dune.lock is up to date. |}];
-  test 1 2 0 1;
-  [%expect {| [Warning]  1/3 packages in dune.lock are outdated. |}];
-  test 2 2 0 1;
-  [%expect {| [Warning]  2/3 packages in dune.lock are outdated. |}];
