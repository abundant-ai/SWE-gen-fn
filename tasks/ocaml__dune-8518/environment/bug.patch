+let is_promoted_rule =
+  let is_promoted_mode version = function
+    | Rule.Mode.Promote { only = None; lifetime; _ } ->
+      if version >= (3, 5)
+      then (
+        match lifetime with
+        | Unlimited -> true
+        | Until_clean -> false)
+      else true
+    | _ -> false
+  in
+  fun version rule ->
