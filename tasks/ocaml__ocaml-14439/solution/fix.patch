+let includes ~affix:sub =
+  let sub_lp = Search.find_maximal_suffix_and_period ~sub in
+  let sub_periodic = Search.is_sub_periodic ~sub ~sub_lp in
+  fun s -> Search.find ~start:0 ~sub ~sub_lp ~sub_periodic s <> -1
