+isSet :: String -> IO (Maybe Bool)
+isSet name = do
+  e <- lookupEnv name
+  case e of
+    Just _ -> return $ Just True
+    Nothing -> return Nothing
+
 maybeTruthy :: String -> IO (Maybe Bool)
