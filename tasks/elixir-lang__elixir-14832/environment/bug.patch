+escape_map_key_value(K, V, Map, Q) ->
+  MaybeRef = if
+    is_reference(V) -> V;
+    is_tuple(V) -> find_tuple_ref(V, 1);
+    true -> nil
+  end,
+  if
+    is_reference(MaybeRef) ->
