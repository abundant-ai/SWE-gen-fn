+      in
+      let stop = Time.now () in
+      start, stop)
+  in
+  Dune_trace.emit ~buffered:true Sandbox (fun () ->
+    let queued = Time.diff start queue_start in
+    Dune_trace.Event.sandbox_destroy ~start ~stop ~queued t.loc ~dir:t.dir)
