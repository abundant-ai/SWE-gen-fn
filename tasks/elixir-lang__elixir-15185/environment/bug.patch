diff --git a/lib/mix/lib/mix/compilers/elixir.ex b/lib/mix/lib/mix/compilers/elixir.ex
index bf8a03ef0..bb05dbd65 100644
--- a/lib/mix/lib/mix/compilers/elixir.ex
