+    | Gt, Gt -> true
+    | Gte, Gte -> true
+    | Lte, Lte -> true
+    | Lt, Lt -> true
+    | Neq, Neq -> true
+    | _ -> false
+  ;;
+
+  let by_string = [ "=", Eq; ">=", Gte; "<=", Lte; ">", Gt; "<", Lt; "<>", Neq ]
+  let to_string t = fst (List.find_exn by_string ~f:(fun (_, op) -> equal op t))
+
+  let encode t =
+    let open Encoder in
+    string (to_string t)
+  ;;
 end
 
