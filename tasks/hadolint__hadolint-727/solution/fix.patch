+      | not (foldArguments forgotToCleanup args) =
+          if foldArguments disabledDockerClean args
+          then st |> modify rememberDockerClean
+          else st
+      | hasCacheDirectory "/var/lib/apt/lists" flags = st
+      | hasCacheDirectory "/var/lib/apt" flags
