diff --git a/src/dune_rules/make_prog.ml b/src/dune_rules/make_prog.ml
new file mode 100644
index 000000000..f63bd51a8
--- /dev/null
+++ b/src/dune_rules/make_prog.ml
@@ -0,0 +1,16 @@
+open Import
+open Memo.O
+
+let which loc context ~path =
+  (let which = Which.which ~path in
+   match Sys.unix with
+   | false -> which "make"
+   | true ->
+     which "gmake"
+     >>= (function
+     | None -> which "make"
+     | Some _ as s -> Memo.return s))
+  >>| function
+  | Some p -> p
+  | None -> Utils.program_not_found ~context ~loc:(Some loc) "make"
+;;
